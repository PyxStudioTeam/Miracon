---
import SeoHead from '../components/SeoHead.astro';

Astro.response.status = 404;
Astro.response.statusText = 'Not Found';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <SeoHead
    title="Page not found — MIRACON"
    description="The requested page could not be found. Explore MIRACON premium residences in Greece."
    noindex
    canonical={false}
  />
  <link rel="stylesheet" href="/style.css">
</head>
<body class="not-found-page">
  <header class="not-found-header">
    <a href="/" class="not-found-logo" aria-label="MIRACON home">
      <img src="/img/logo_mark.svg" alt="">
      <span>MIRACON</span>
    </a>
    <a href="/#contacts" class="not-found-contact">Contact</a>
  </header>

  <main class="not-found-main">
    <div class="not-found-copy">
      <p class="not-found-code" aria-hidden="true">404</p>
      <p class="not-found-kicker">Page not found</p>
      <h1>This address does not lead to a residence yet.</h1>
      <p class="not-found-text">The page may have moved or the link may be incorrect. Return home or browse the current MIRACON projects.</p>
      <div class="not-found-actions">
        <a href="/" class="not-found-primary">Back to home <span aria-hidden="true">→</span></a>
        <a href="/#projects" class="not-found-secondary">Explore projects</a>
      </div>
    </div>
    <div class="not-found-mark" aria-hidden="true">
      <img src="/img/logo_mark.svg" alt="">
    </div>
  </main>

  <footer class="not-found-footer">
    <span>Premium residences in Greece</span>
    <a href="tel:+306955340416">+30 695 534 0416</a>
  </footer>
</body>
</html>

<style>
  :global(html) { background: #f5f2ec; }
  :global(body.not-found-page) { min-width: 0; min-height: 100svh; margin: 0; display: grid; grid-template-rows: auto 1fr auto; overflow-x: hidden; background: #f5f2ec; color: #003075; font-family: Gilroy, 'Plus Jakarta Sans', Arial, sans-serif; }
  .not-found-header { width: min(100% - 64px, 1440px); margin: 0 auto; padding: 30px 0; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid rgba(0, 48, 117, .18); }
  .not-found-logo { display: inline-flex; align-items: center; gap: 10px; color: #003075; text-decoration: none; font-family: Georgia, serif; font-size: 20px; }
  .not-found-logo img { width: 34px; height: 34px; object-fit: contain; filter: invert(16%) sepia(69%) saturate(2109%) hue-rotate(198deg) brightness(79%) contrast(105%); }
  .not-found-contact { padding: 13px 24px; border: 1px solid #003075; border-radius: 999px; color: #003075; text-decoration: none; font-size: 15px; }
  .not-found-main { width: min(100% - 64px, 1440px); margin: 0 auto; padding: clamp(56px, 8vw, 120px) 0; display: grid; grid-template-columns: minmax(0, 760px) 1fr; align-items: center; gap: clamp(48px, 8vw, 140px); }
  .not-found-copy { position: relative; z-index: 1; }
  .not-found-code { margin: 0 0 -18px; color: #cb994b; font-size: clamp(88px, 11vw, 170px); font-weight: 300; line-height: .85; letter-spacing: -.07em; }
  .not-found-kicker { margin: 40px 0 16px; color: #cb994b; font-size: 14px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; }
  .not-found-copy h1 { max-width: 720px; margin: 0; font-size: clamp(42px, 5.5vw, 82px); font-weight: 300; line-height: .96; letter-spacing: -.04em; }
  .not-found-text { max-width: 600px; margin: 28px 0 0; color: rgba(0, 48, 117, .72); font-size: clamp(17px, 1.4vw, 21px); line-height: 1.45; }
  .not-found-actions { margin-top: 36px; display: flex; flex-wrap: wrap; align-items: center; gap: 14px; }
  .not-found-primary, .not-found-secondary { min-height: 52px; padding: 0 28px; display: inline-flex; align-items: center; justify-content: center; gap: 28px; border-radius: 999px; text-decoration: none; font-size: 16px; }
  .not-found-primary { background: #003075; color: #fff; }
  .not-found-secondary { border: 1px solid rgba(0, 48, 117, .35); color: #003075; }
  .not-found-mark { justify-self: end; width: min(30vw, 390px); aspect-ratio: 1; display: grid; place-items: center; border: 1px solid rgba(0, 48, 117, .14); border-radius: 50%; }
  .not-found-mark img { width: 54%; height: 54%; object-fit: contain; opacity: .13; filter: invert(16%) sepia(69%) saturate(2109%) hue-rotate(198deg) brightness(79%) contrast(105%); }
  .not-found-footer { width: min(100% - 64px, 1440px); margin: 0 auto; padding: 26px 0 32px; display: flex; justify-content: space-between; gap: 20px; border-top: 1px solid rgba(0, 48, 117, .18); color: rgba(0, 48, 117, .68); font-size: 14px; }
  .not-found-footer a { color: inherit; text-decoration: none; }

  @media (max-width: 720px) {
    .not-found-header, .not-found-main, .not-found-footer { width: calc(100% - 36px); }
    .not-found-header { padding: 20px 0; }
    .not-found-logo { font-size: 17px; }
    .not-found-logo img { width: 28px; height: 28px; }
    .not-found-contact { padding: 10px 18px; font-size: 14px; }
    .not-found-main { padding: 54px 0 64px; display: block; }
    .not-found-code { margin-bottom: -6px; font-size: clamp(92px, 31vw, 132px); }
    .not-found-kicker { margin-top: 28px; }
    .not-found-copy h1 { font-size: clamp(38px, 12vw, 56px); }
    .not-found-text { margin-top: 22px; font-size: 17px; }
    .not-found-actions { align-items: stretch; flex-direction: column; }
    .not-found-primary, .not-found-secondary { width: 100%; box-sizing: border-box; }
    .not-found-mark { display: none; }
    .not-found-footer { padding: 22px 0 26px; align-items: flex-start; flex-direction: column; }
  }
</style>
