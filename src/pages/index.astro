---
import ProjectCard from '../components/ProjectCard.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import SeoHead from '../components/SeoHead.astro';
import { getHomeHeroVideos } from '../lib/home-hero';
import { getPublishedProjects } from '../lib/projects';
import { absoluteSiteUrl } from '../lib/seo';

const projects = await getPublishedProjects();
const homeHeroVideos = await getHomeHeroVideos();
const firstHomeHeroVideo = homeHeroVideos[0];
const serializedHomeHeroVideos = JSON.stringify(homeHeroVideos.map((video) => ({
  id: video.id,
  title: video.title,
  desktopUrl: video.desktopUrl,
  mobileUrl: video.mobileUrl,
})));
const homeUrl = absoluteSiteUrl('/', Astro.url);
const homeStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${homeUrl}#website`,
      url: homeUrl,
      name: 'MIRACON',
      inLanguage: 'en',
    },
    {
      '@type': 'Organization',
      '@id': `${homeUrl}#organization`,
      name: 'MIRACON',
      url: homeUrl,
      logo: {
        '@type': 'ImageObject',
        url: absoluteSiteUrl('/favicon.svg', Astro.url),
        width: 512,
        height: 512,
      },
      image: absoluteSiteUrl('/img/figma_hero.png', Astro.url),
      telephone: '+306955340416',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Egnatia 84',
        postalCode: '54623',
        addressLocality: 'Thessaloniki',
        addressCountry: 'GR',
      },
    },
  ],
};
---
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <base href="/">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <SeoHead
    title="MIRACON — Premium Residences in Greece"
    description="Premium residences and prime locations in Thessaloniki and Halkidiki. Direct Greek developer with full legal support."
    path="/"
    image="/img/figma_hero.png"
    imageAlt="MIRACON premium residences in Greece"
    jsonLd={homeStructuredData}
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/mobile.css">
</head>

<body>
  <header class="header">
    <div class="header-container">
      <a href="/" class="logo" aria-label="MIRACON home">
        <img src="img/logo_mark.svg" alt="" class="logo-img">
        <div class="logo-letters" aria-hidden="true">
          <img src="img/logo_letters/M.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/I.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/R.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/A.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/C.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/O.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/N.svg" alt="" class="logo-letter">
        </div>
      </a>

      <nav class="nav-menu glass-gradient" aria-label="Main navigation">
        <a href="#projects" class="nav-link">Projects</a>
        <a href="/golden-visa" class="nav-link">Golden Visa</a>
        <a href="#about" class="nav-link">About us</a>
        <a href="#contacts" class="nav-link">Contacts</a>
      </nav>

      <div class="header-actions">
        <div class="lang-selector glass-gradient">
          <span class="lang-current">EN</span>
        </div>
        <div class="contact-menu">
          <a href="#contacts" class="contact-btn" aria-haspopup="true">
            <span class="contact-btn-icon"></span>
            <span>Contact</span>
            <span class="contact-btn-arrow" aria-hidden="true">
              <img src="img/contact_header/Vector 12.svg" alt="">
            </span>
          </a>
          <div class="contact-dropdown" aria-label="Quick contact links">
            <a href="tel:+306955340416" class="contact-dropdown-link contact-dropdown-link--phone"
              aria-label="Call +306955340416">
              <span class="contact-dropdown-text">+306955340416</span>
              <span class="contact-dropdown-circle" aria-hidden="true">
                <img src="img/contact_header/Vector (1).svg" alt="">
              </span>
            </a>
            <a href="mailto:info@miracon.gr" class="contact-dropdown-link contact-dropdown-link--mail"
              aria-label="Email info@miracon.gr">
              <span class="contact-dropdown-text">info@miracon.gr</span>
              <span class="contact-dropdown-circle" aria-hidden="true">
                <img src="img/contact_header/Group 37313 (1).svg" alt="">
              </span>
            </a>
            <a href="https://www.google.com/maps/search/?api=1&query=Egnatia+84%2C+54623+Thessaloniki%2C+Greece"
              class="contact-dropdown-link contact-dropdown-link--geo" target="_blank" rel="noreferrer"
              aria-label="Open Egnatia 84, 54623 Thessaloniki, Greece in Google Maps">
              <span class="contact-dropdown-text">Egnatia 84, 54623 Thessaloniki, Greece</span>
              <span class="contact-dropdown-circle" aria-hidden="true">
                <img src="img/contact_header/Vector (2).svg" alt="">
              </span>
            </a>
          </div>
        </div>
      </div>

      <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Open menu" aria-controls="mobileNav" aria-expanded="false">
        <span aria-hidden="true"></span>
      </button>
      <nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
        <a href="#projects" class="mobile-nav-link">Projects</a>
        <a href="/golden-visa" class="mobile-nav-link">Golden Visa</a>
        <a href="#about" class="mobile-nav-link">About us</a>
        <button class="mobile-nav-contact" type="button" aria-expanded="false" aria-controls="mobileContactDetails">
          <span>Contacts</span><span aria-hidden="true">+</span>
        </button>
        <div class="mobile-nav-contacts" id="mobileContactDetails">
          <a href="tel:+306955340416">+30 695 534 0416</a>
          <a href="mailto:info@miracon.gr">info@miracon.gr</a>
          <a href="https://www.google.com/maps/search/?api=1&query=Egnatia+84%2C+54623+Thessaloniki%2C+Greece" target="_blank" rel="noreferrer">Egnatia 84, Thessaloniki</a>
        </div>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero-pin" aria-label="MIRACON hero">
      <div class="hero">
        <div class="hero-media" data-home-hero-playlist={serializedHomeHeroVideos}>
          <video class="hero-video is-active" autoplay muted loop={homeHeroVideos.length === 1} playsinline preload="auto" poster="/img/figma_hero.png">
            <source media="(max-width: 600px)" src={firstHomeHeroVideo.mobileUrl ?? firstHomeHeroVideo.desktopUrl} type="video/mp4">
            <source src={firstHomeHeroVideo.desktopUrl} type="video/mp4">
          </video>
          <video class="hero-video" muted playsinline preload="none" poster="/img/figma_hero.png" aria-hidden="true"></video>
        </div>
        <div class="container hero-content">
          <p class="hero-subtitle">Thessaloniki · Halkidiki · Greece</p>
          <h1 class="hero-title">Premium Residences<br>Prime Locations</h1>
          <div class="hero-actions">
            <a href="#projects" class="btn-hero">
              <span class="btn-arrow btn-arrow-left"></span>
              <span>Explore projects</span>
            </a>
            <a href="/golden-visa" class="badge-visa glass-gradient">Golden Visa from €250k</a>
          </div>
        </div>
        <a href="#projects" class="hero-scroll-indicator" aria-label="Scroll to projects">
          <img src="img/arrow_white.svg" alt="" aria-hidden="true">
        </a>
      </div>
    </section>

    <section id="projects" class="projects-section">
      <div class="container">
        <h2 class="section-title">Projects</h2>
        <p class="section-subtitle">Three exclusive developments. Two prime locations. One trusted developer</p>

        <div class="filter-tabs" aria-label="Project filters">
          <button class="filter-tab active" type="button" data-filter="all" aria-pressed="true" aria-controls="projectsList"><span data-label="All">All</span></button>
          <button class="filter-tab" type="button" data-filter="coastal" aria-pressed="false" aria-controls="projectsList"><span data-label="Coastal">Coastal</span></button>
          <button class="filter-tab" type="button" data-filter="city" aria-pressed="false" aria-controls="projectsList"><span data-label="City">City</span></button>
          <button class="filter-tab" type="button" data-filter="golden-visa" aria-pressed="false" aria-controls="projectsList"><span data-label="Golden Visa">Golden
              Visa</span></button>
        </div>

        <div class="projects-list" id="projectsList">
          {projects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>

    <section id="about" class="about-section">
      <div class="container about-container">
        <div class="about-copy">
          <h2 class="about-heading about-reveal" aria-label="About MIRACON">
            <span class="about-title-word" aria-hidden="true">About</span>
            <span class="about-brand" aria-hidden="true">
              <span class="about-brand-letter about-brand-letter-m"></span>
              <span class="about-brand-letter about-brand-letter-i"></span>
              <span class="about-brand-letter about-brand-letter-r"></span>
              <span class="about-brand-letter about-brand-letter-a"></span>
              <span class="about-brand-letter about-brand-letter-c"></span>
              <span class="about-brand-letter about-brand-letter-o"></span>
              <span class="about-brand-letter about-brand-letter-n"></span>
            </span>
          </h2>
          <p class="section-subtitle about-reveal">We build. We sell. We stay with you</p>
          <div class="about-text about-reveal">
            <p>MIRACON Constructions develops modern residential properties in Thessaloniki — Greece's second-largest
              city and a key gateway between Europe and Asia. Located on the Aegean coast, with direct access to the
              Balkans and close proximity to Turkey and major European markets, it offers a rare combination of
              lifestyle, connectivity, and investment potential.</p>
            <p>Our portfolio includes contemporary city apartments in central Thessaloniki, boutique residential
              projects
              in coastal Halkidiki, premium villas with panoramic sea views — all fully eligible for the Greek Golden
              Visa program.</p>
          </div>
        </div>
        <OptimizedImage src="/img/about_bg.png" alt="Premium residence with sea view" class="about-image about-reveal" loading="lazy" decoding="async" />
      </div>

      <div class="about-carousel" aria-label="MIRACON benefits">
        <div class="about-carousel-track">
          <div class="about-carousel-set">
            <article class="about-card about-card-direct">
              <img src="img/about_carousel/Group 2136141923.svg" alt="" class="about-card-icon">
              <h3>Direct developer</h3>
              <p>No agencies. No markups. You buy from the builder at a transparent price</p>
            </article>
            <article class="about-card about-card-legal">
              <img src="img/about_carousel/Group 2136141905.svg" alt="" class="about-card-icon">
              <h3>Full legal support</h3>
              <p>AFM registration, bank account, title transfer, Golden Visa filing — we handle it all</p>
            </article>
            <article class="about-card about-card-personal">
              <img src="img/about_carousel/Group 2136141924.svg" alt="" class="about-card-icon">
              <h3>Personal approach</h3>
              <p>A dedicated manager guides you from first enquiry to key handover — and beyond</p>
            </article>
            <article class="about-card about-card-locations">
              <img src="img/about_carousel/Group 2136141925.svg" alt="" class="about-card-icon">
              <h3>Prime locations</h3>
              <p>First-line Halkidiki coast and central Thessaloniki — prime markets in Northern Greece</p>
            </article>
          </div>

          <div class="about-carousel-set" aria-hidden="true">
            <article class="about-card about-card-direct">
              <img src="img/about_carousel/Group 2136141923.svg" alt="" class="about-card-icon">
              <h3>Direct developer</h3>
              <p>No agencies. No markups. You buy from the builder at a transparent price</p>
            </article>
            <article class="about-card about-card-legal">
              <img src="img/about_carousel/Group 2136141905.svg" alt="" class="about-card-icon">
              <h3>Full legal support</h3>
              <p>AFM registration, bank account, title transfer, Golden Visa filing — we handle it all</p>
            </article>
            <article class="about-card about-card-personal">
              <img src="img/about_carousel/Group 2136141924.svg" alt="" class="about-card-icon">
              <h3>Personal approach</h3>
              <p>A dedicated manager guides you from first enquiry to key handover — and beyond</p>
            </article>
            <article class="about-card about-card-locations">
              <img src="img/about_carousel/Group 2136141925.svg" alt="" class="about-card-icon">
              <h3>Prime locations</h3>
              <p>First-line Halkidiki coast and central Thessaloniki — prime markets in Northern Greece</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="golden-visa" class="golden-visa-section">
      <div class="container golden-container">
        <div class="golden-image-wrap">
          <div class="golden-carousel-3d">
            <div class="golden-carousel-inner">
              <div class="golden-carousel-face">
                <picture>
                  <source media="(max-width: 600px)" srcset="/img/figma-mobile/golden-visa.avif" type="image/avif">
                  <source media="(max-width: 600px)" srcset="/img/figma-mobile/golden-visa.png">
                  <source srcset="/img/figma_golden_visa.avif" type="image/avif">
                  <img src="/img/figma_golden_visa.png" alt="Greek Residency" loading="lazy" decoding="async">
                </picture>
              </div>
              <div class="golden-carousel-face">
                <picture>
                  <source srcset="/img/golden_visa_2.avif" type="image/avif">
                  <img src="/img/golden_visa_2.png" alt="Investment threshold" loading="lazy" decoding="async">
                </picture>
              </div>
              <div class="golden-carousel-face">
                <picture>
                  <source srcset="/img/golden_visa_3.avif" type="image/avif">
                  <img src="/img/golden_visa_3.png" alt="Family included" loading="lazy" decoding="async">
                </picture>
              </div>
              <div class="golden-carousel-face">
                <picture>
                  <source srcset="/img/golden_visa_4.avif" type="image/avif">
                  <img src="/img/golden_visa_4.png" alt="Schengen access" loading="lazy" decoding="async">
                </picture>
              </div>
            </div>
          </div>
          <a href="/golden-visa" class="visa-consult-badge glass-gradient">
            <span>More details</span>
            <span class="visa-consult-arrow"></span>
          </a>
        </div>

        <div class="golden-content">
          <h2 class="section-title">Golden Visa</h2>
          <p class="section-subtitle">EU residency through property investment — from €250,000</p>

          <div class="slider-wrapper" aria-label="Golden Visa benefits">
            <div class="slider-slides">
              <article class="slide active">
                <h3 class="slide-title">
                  <img src="img/golden_visa/Subtract_1.svg" alt="" class="slide-icon">
                  Greek Residency
                </h3>
                <p class="slide-text">Greece offers one of Europe's most accessible residency-by-investment programmes.
                  Purchase qualifying real estate and receive a 5-year renewable residence permit for your entire family
                  — no minimum stay required</p>
              </article>
              <article class="slide">
                <h3 class="slide-title">
                  <img src="img/golden_visa/trending-up_2.svg" alt="" class="slide-icon">
                  Investment threshold
                </h3>
                <p class="slide-text">The minimum qualifying investment is €250,000. Selected residences at Monastiriou 4
                  in central Thessaloniki meet this threshold — making MIRACON projects an ideal entry point into the
                  programme</p>
              </article>
              <article class="slide">
                <h3 class="slide-title">
                  <img src="img/golden_visa/Vector_3.svg" alt="" class="slide-icon">
                  Family included
                </h3>
                <p class="slide-text">The residence permit covers the investor, spouse, children under 21, and both sets
                  of parents. No additional fees per family member. The permit is renewed every 5 years as long as the
                  property is owned</p>
              </article>
              <article class="slide">
                <h3 class="slide-title">
                  <img src="img/golden_visa/keypad_4.svg" alt="" class="slide-icon">
                  Schengen access
                </h3>
                <p class="slide-text slide-text-short">As a Greek residence permit holder you can travel freely across
                  26
                  Schengen countries without a visa. No minimum stay in Greece required — visit when you wish, live
                  where
                  you want</p>
              </article>
            </div>

            <div class="slider-controls">
              <button class="slider-btn btn-prev" aria-label="Previous Golden Visa card"></button>
              <span class="slider-counter">1/4</span>
              <button class="slider-btn btn-next" aria-label="Next Golden Visa card"></button>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="stages-section">
      <div class="container stages-container">
        <div class="stages-intro">
          <h2 class="section-title">Stage of work</h2>
          <p class="section-subtitle">A clear process from first contact to key handover</p>
        </div>
      </div>

      <div class="stages-carousel" aria-label="Stages of work">
        <div class="stages-carousel-track">
          <div class="stages-carousel-set">
            <article class="stage-card">
              <span class="stage-number">01</span>
              <h3>Consultation</h3>
              <p>We find the right property for your goals</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">02</span>
              <h3>Reservation</h3>
              <p>Deposit placed,<br>unit secured</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">03</span>
              <h3>Due Diligence</h3>
              <p>AFM, bank account,<br>due diligence</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">04</span>
              <h3>Purchase</h3>
              <p>Signed before<br>a Greek notary</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">05</span>
              <h3>Handover</h3>
              <p>Fully finished.<br>Ready to move in</p>
            </article>
          </div>

          <div class="stages-carousel-set" aria-hidden="true">
            <article class="stage-card">
              <span class="stage-number">01</span>
              <h3>Consultation</h3>
              <p>We find the right property for your goals</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">02</span>
              <h3>Reservation</h3>
              <p>Deposit placed,<br>unit secured</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">03</span>
              <h3>Due Diligence</h3>
              <p>AFM, bank account,<br>due diligence</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">04</span>
              <h3>Contract</h3>
              <p>Documents signed,<br>payment schedule fixed</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">05</span>
              <h3>Key handover</h3>
              <p>Property delivered,<br>support continues</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="contacts" class="contacts-section">
      <div class="container">
        <div class="form-container">
          <h2 class="section-title">Free consultation</h2>
          <p class="section-subtitle">Lorem ipsum dolo lorem ipsum dolor sit amet<br>consecteturr</p>

          <form class="consultation-form" data-consultation-form data-web3forms-key="bcf7cde0-e5e8-4908-8b89-02ebe78bcd0d" novalidate>
            <div class="form-row">
              <label class="form-group">
                <span>Name</span>
                <input type="text" name="name" class="form-input" placeholder="Name" required>
              </label>
              <label class="form-group">
                <span>Phone</span>
                <input type="tel" name="phone" class="form-input" placeholder="Phone">
              </label>
              <label class="form-group">
                <span>Email</span>
                <input type="email" name="email" class="form-input" placeholder="Email">
              </label>
            </div>

            <label class="form-group form-message">
              <span>What info are you interested in?</span>
              <textarea name="message" class="form-input form-textarea" placeholder="What info are you interested in?"></textarea>
            </label>

            <label class="form-consent">
              <input type="checkbox" name="consent" class="form-consent-input" required>
              <span class="form-consent-box" aria-hidden="true"></span>
              <span class="form-consent-text">I agree to the processing of my personal data in accordance with the <a
                  href="#">Privacy Policy</a> and consent to being contacted using the details provided</span>
            </label>

            <button type="submit" class="btn-submit" disabled>
              <span>Request a consultation</span>
              <span class="btn-submit-arrow"></span>
            </button>
            <input class="form-honeypot" type="checkbox" name="botcheck" tabindex="-1" aria-hidden="true">
            <p class="form-status" aria-live="polite" hidden></p>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-container">
      <div class="footer-top">
        <a href="/" class="logo" aria-label="MIRACON home">
          <img src="img/logo_mark.svg" alt="" class="logo-img">
          <div class="logo-letters" aria-hidden="true">
            <img src="img/logo_letters/M.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/I.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/R.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/A.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/C.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/O.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/N.svg" alt="" class="logo-letter">
          </div>
        </a>
        <div class="footer-socials">
          <a href="#" aria-label="LinkedIn">
            <img src="img/links/Link → Img.svg" alt="">
          </a>
          <a href="#" aria-label="Facebook">
            <img src="img/links/Link → Img-1.svg" alt="">
          </a>
          <a href="#" aria-label="Instagram">
            <img src="img/links/Link → Img-2.svg" alt="">
          </a>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-links">
          <a href="#">Terms of Use</a>
          <a href="#">Privacy Policy</a>
          <a href="#">Cookie Policy</a>
        </div>
        <button class="lang-dropdown-btn">
          <span>English</span>
          <span class="lang-refresh" aria-hidden="true">
            <img src="img/Vector.svg" alt="">
          </span>
        </button>
      </div>
    </div>
  </footer>

  <script is:inline src="/site.js"></script>
</body>
</html>
