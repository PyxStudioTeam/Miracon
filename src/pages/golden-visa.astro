---
import ProjectCard from '../components/ProjectCard.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import SeoHead from '../components/SeoHead.astro';
import { getPublishedProjects } from '../lib/projects';
import { absoluteSiteUrl } from '../lib/seo';

const goldenVisaProjects = (await getPublishedProjects()).filter((project) => project.categories.includes('golden-visa'));
const goldenVisaUrl = absoluteSiteUrl('/golden-visa', Astro.url);
const goldenVisaStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${goldenVisaUrl}#webpage`,
      url: goldenVisaUrl,
      name: 'Golden Visa — MIRACON',
      description: 'Greek Golden Visa through qualifying MIRACON real estate investments in Thessaloniki and Halkidiki.',
      inLanguage: 'en',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteSiteUrl('/', Astro.url) },
        { '@type': 'ListItem', position: 2, name: 'Golden Visa', item: goldenVisaUrl },
      ],
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <base href="/">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <SeoHead
    title="Golden Visa — MIRACON"
    description="Greek Golden Visa through qualifying MIRACON real estate investments in Thessaloniki and Halkidiki."
    path="/golden-visa"
    image="/img/golden-visa/hero-interior.jpg"
    imageAlt="Premium residence interior in Greece"
    jsonLd={goldenVisaStructuredData}
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@qpokychuk/gilroy@1.0.2/index.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/golden-visa.css">
  <link rel="stylesheet" href="/inner-mobile.css">
</head>

<body class="golden-visa-page">
  <header class="header">
    <div class="header-container">
      <a href="/" class="logo" aria-label="MIRACON home">
        <img src="img/logo_mark.svg" alt="" class="logo-img">
        <div class="logo-letters" aria-hidden="true">
          <img src="img/logo_letters/M.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/I.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/R.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/A.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/C.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/O.svg" alt="" class="logo-letter">
          <img src="img/logo_letters/N.svg" alt="" class="logo-letter">
        </div>
      </a>

      <nav class="nav-menu glass-gradient" aria-label="Main navigation">
        <a href="#projects" class="nav-link">Projects</a>
        <a href="#top" class="nav-link nav-link-current" aria-current="page">Golden Visa</a>
        <a href="/#about" class="nav-link">About us</a>
        <a href="#contacts" class="nav-link">Contacts</a>
      </nav>

      <div class="header-actions">
        <div class="lang-selector glass-gradient">
          <span class="lang-current">EN</span>
        </div>
        <div class="contact-menu">
          <a href="#contacts" class="contact-btn" aria-haspopup="true">
            <span class="contact-btn-icon"></span>
            <span>Contact</span>
            <span class="contact-btn-arrow" aria-hidden="true">
              <img src="img/contact_header/Vector 12.svg" alt="">
            </span>
          </a>
          <div class="contact-dropdown" aria-label="Quick contact links">
            <a href="tel:+306955340416" class="contact-dropdown-link contact-dropdown-link--phone"
              aria-label="Call +306955340416">
              <span class="contact-dropdown-text">+306955340416</span>
              <span class="contact-dropdown-circle" aria-hidden="true">
                <img src="img/contact_header/Vector (1).svg" alt="">
              </span>
            </a>
            <a href="mailto:miracon@miracon.gr" class="contact-dropdown-link contact-dropdown-link--mail"
              aria-label="Email miracon@miracon.gr">
              <span class="contact-dropdown-text">miracon@miracon.gr</span>
              <span class="contact-dropdown-circle" aria-hidden="true">
                <img src="img/contact_header/Group 37313 (1).svg" alt="">
              </span>
            </a>
            <a href="https://www.google.com/maps/search/?api=1&query=Egnatia+84%2C+54623+Thessaloniki%2C+Greece"
              class="contact-dropdown-link contact-dropdown-link--geo" target="_blank" rel="noreferrer"
              aria-label="Open Egnatia 84, 54623 Thessaloniki, Greece in Google Maps">
              <span class="contact-dropdown-text">Egnatia 84, 54623 Thessaloniki, Greece</span>
              <span class="contact-dropdown-circle" aria-hidden="true">
                <img src="img/contact_header/Vector (2).svg" alt="">
              </span>
            </a>
          </div>
        </div>
      </div>

      <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" aria-label="Open menu" aria-controls="mobileNav" aria-expanded="false">
        <span aria-hidden="true"></span>
      </button>
      <nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation">
        <a href="/#projects" class="mobile-nav-link">Projects</a>
        <a href="#top" class="mobile-nav-link" aria-current="page">Golden Visa</a>
        <a href="/#about" class="mobile-nav-link">About us</a>
        <a href="#contacts" class="mobile-nav-link">Contacts</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="gv-hero" aria-labelledby="golden-visa-title">
      <OptimizedImage src="/img/golden-visa/hero-beach.jpg" alt="Beachfront residences in Greece" class="gv-hero-bg gv-hero-bg-base" fetchpriority="high" decoding="async" />
      <OptimizedImage src="/img/golden-visa/hero-interior.jpg" alt="Premium residence interior" class="gv-hero-bg gv-hero-bg-front" fetchpriority="high" decoding="async" />
      <div class="gv-hero-softener" aria-hidden="true"></div>
      <div class="container gv-hero-content">
        <h1 id="golden-visa-title">Your Pathway<br>to Greek Residency</h1>
        <p class="gv-hero-lead">Secure your Greek Golden Visa through prime real estate investments in Thessaloniki &amp;
          Halkidiki with MIRACON Constructions</p>
        <div class="gv-hero-actions hero-actions">
          <a href="#projects" class="btn-hero">
            <span class="btn-arrow btn-arrow-left"></span>
            <span>Explore projects</span>
          </a>
          <a href="#projects" class="badge-visa glass-gradient">Golden Visa from €250k</a>
        </div>
      </div>
    </section>

    <section class="gv-threshold" aria-labelledby="gv-threshold-title">
      <div class="container">
        <div class="gv-threshold-card">
          <div class="gv-threshold-main">
            <h2 id="gv-threshold-title">€250 000</h2>
            <p>investment option for obtaining a Golden Visa in the European Union</p>
            <span>- the most affordable</span>
          </div>
          <span class="gv-threshold-divider" aria-hidden="true"></span>
          <div class="gv-threshold-note">
            <span class="gv-warning-icon" aria-hidden="true">
              <img src="img/golden-visa/warning-shape.svg" alt="" class="gv-warning-shape">
              <img src="img/golden-visa/warning-mark.svg" alt="" class="gv-warning-mark">
            </span>
            <p>For standard residential property purchases in most regions of Greece, the minimum investment is
              <strong>€400,000</strong></p>
          </div>
        </div>
      </div>
    </section>

    <section class="gv-family" aria-labelledby="gv-family-title">
      <div class="container gv-family-container">
        <h2 id="gv-family-title" class="section-title">Family Eligibility</h2>
        <p class="section-subtitle">Eligibility for the Golden Visa extends not only to the property owner, but also to:</p>

        <div class="gv-family-panel">
          <a href="#contacts" class="gv-primary-cta">
            <span>Get Your Golden Visa Now</span>
            <span class="btn-submit-arrow" aria-hidden="true"></span>
          </a>

          <div class="gv-family-cards">
            <article class="gv-family-card">
              <img src="img/golden-visa/icon-children.svg" alt="" aria-hidden="true">
              <h3>Spouse</h3>
            </article>
            <article class="gv-family-card">
              <img src="img/golden-visa/icon-parents.svg" alt="" aria-hidden="true">
              <h3>Children of both spouses under 21</h3>
            </article>
            <article class="gv-family-card">
              <img src="img/golden-visa/icon-spouse.svg" alt="" aria-hidden="true">
              <h3>Parents of both spouses</h3>
            </article>
            <article class="gv-family-card">
              <img src="img/golden-visa/icon-application.svg" alt="" aria-hidden="true">
              <h3>One application for the whole family</h3>
            </article>
          </div>

          <div class="gv-family-summary">
            <img src="img/golden-visa/icon-application-large.svg" alt="" class="gv-family-summary-icon" aria-hidden="true">
            <div class="gv-family-summary-copy">
              <h3>Family Inclusion</h3>
              <p>The Greek Golden Visa grants residency rights to the investor and eligible family members under a single
                application structure, providing long-term flexibility, mobility within the Schengen Area and access to
                local services</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="gv-metrics" aria-label="Golden Visa key figures">
      <div class="gv-metrics-track">
        <div class="gv-metrics-set">
          <article class="gv-metric-card">
            <h3>33 countries</h3>
            <p>Will be accessible for visit</p>
          </article>
          <article class="gv-metric-card">
            <h3>€250 000</h3>
            <p>Minimum investment</p>
          </article>
          <article class="gv-metric-card">
            <h3>5 years</h3>
            <p>Permit duration, renewable while property is owned</p>
          </article>
          <article class="gv-metric-card">
            <h3>100%</h3>
            <p>Guarantee of the EU residence permit</p>
          </article>
          <article class="gv-metric-card">
            <h3>~€20 000</h3>
            <p>Additional official state charges for processing</p>
          </article>
        </div>

        <div class="gv-metrics-set" aria-hidden="true">
          <article class="gv-metric-card">
            <h3>33 countries</h3>
            <p>Will be accessible for visit</p>
          </article>
          <article class="gv-metric-card">
            <h3>€250 000</h3>
            <p>Minimum investment</p>
          </article>
          <article class="gv-metric-card">
            <h3>5 years</h3>
            <p>Permit duration, renewable while property is owned</p>
          </article>
          <article class="gv-metric-card">
            <h3>100%</h3>
            <p>Guarantee of the EU residence permit</p>
          </article>
          <article class="gv-metric-card">
            <h3>~€20 000</h3>
            <p>Additional official state charges for processing</p>
          </article>
        </div>
      </div>
    </section>

    <section id="projects" class="projects-section gv-projects">
      <div class="container">
        <h2 class="section-title">{goldenVisaProjects.length === 1 ? 'Featured Property' : 'Golden Visa Properties'}</h2>
        <p class="section-subtitle">Properties eligible for the Greek Golden Visa programme</p>

        <div class="projects-list">
          {goldenVisaProjects.length > 0
            ? goldenVisaProjects.map((project) => <ProjectCard project={project} />)
            : <p class="gv-projects-empty">Golden Visa properties will appear here when published.</p>}
        </div>
      </div>
    </section>

    <section class="stages-section">
      <div class="container stages-container">
        <div class="stages-intro">
          <h2 class="section-title">Stage of work</h2>
          <p class="section-subtitle">A clear process from first contact to key handover.</p>
        </div>
      </div>

      <div class="stages-carousel" aria-label="Stages of work">
        <div class="stages-carousel-track">
          <div class="stages-carousel-set">
            <article class="stage-card">
              <span class="stage-number">01</span>
              <h3>Consultation</h3>
              <p>We find the right property for your goals</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">02</span>
              <h3>Reservation</h3>
              <p>Deposit placed,<br>unit secured</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">03</span>
              <h3>Due Diligence</h3>
              <p>AFM, bank account,<br>due diligence</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">04</span>
              <h3>Contract</h3>
              <p>Documents signed,<br>payment schedule fixed</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">05</span>
              <h3>Key handover</h3>
              <p>Property delivered,<br>support continues</p>
            </article>
          </div>

          <div class="stages-carousel-set" aria-hidden="true">
            <article class="stage-card">
              <span class="stage-number">01</span>
              <h3>Consultation</h3>
              <p>We find the right property for your goals</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">02</span>
              <h3>Reservation</h3>
              <p>Deposit placed,<br>unit secured</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">03</span>
              <h3>Due Diligence</h3>
              <p>AFM, bank account,<br>due diligence</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">04</span>
              <h3>Contract</h3>
              <p>Documents signed,<br>payment schedule fixed</p>
            </article>
            <article class="stage-card">
              <span class="stage-number">05</span>
              <h3>Key handover</h3>
              <p>Property delivered,<br>support continues</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section id="contacts" class="contacts-section">
      <div class="container">
        <div class="form-container">
          <h2 class="section-title">Free consultation</h2>
          <p class="section-subtitle">Lorem ipsum dolo lorem ipsum dolor sit amet consecteturr</p>

          <form class="consultation-form" id="consultationForm">
            <div class="form-row">
              <label class="form-group">
                <span>Name</span>
                <input type="text" id="formName" class="form-input" placeholder="Name">
              </label>
              <label class="form-group">
                <span>Phone</span>
                <input type="tel" id="formPhone" class="form-input" placeholder="Phone">
              </label>
              <label class="form-group">
                <span>Email</span>
                <input type="email" id="formEmail" class="form-input" placeholder="Email">
              </label>
            </div>

            <label class="form-group form-message">
              <span>What info are you interested in?</span>
              <textarea id="formMessage" class="form-input form-textarea" placeholder="What info are you interested in?"></textarea>
            </label>

            <label class="form-consent">
              <input type="checkbox" id="formConsent" class="form-consent-input">
              <span class="form-consent-box" aria-hidden="true"></span>
              <span class="form-consent-text">I agree to the processing of my personal data in accordance with the <a
                  href="#">Privacy Policy</a> and consent to being contacted using the details provided</span>
            </label>

            <button type="submit" class="btn-submit" disabled>
              <span>Request a consultation</span>
              <span class="btn-submit-arrow"></span>
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-container">
      <div class="footer-top">
        <a href="/" class="logo" aria-label="MIRACON home">
          <img src="img/logo_mark.svg" alt="" class="logo-img">
          <div class="logo-letters" aria-hidden="true">
            <img src="img/logo_letters/M.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/I.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/R.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/A.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/C.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/O.svg" alt="" class="logo-letter">
            <img src="img/logo_letters/N.svg" alt="" class="logo-letter">
          </div>
        </a>
        <div class="footer-socials">
          <a href="#" aria-label="LinkedIn">
            <img src="img/links/Link → Img.svg" alt="">
          </a>
          <a href="#" aria-label="Facebook">
            <img src="img/links/Link → Img-1.svg" alt="">
          </a>
          <a href="#" aria-label="Instagram">
            <img src="img/links/Link → Img-2.svg" alt="">
          </a>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-links">
          <a href="#">Terms of Use</a>
          <a href="#">Privacy Policy</a>
          <a href="#">Cookie Policy</a>
        </div>
        <button class="lang-dropdown-btn">
          <span>English</span>
          <span class="lang-refresh" aria-hidden="true">
            <img src="img/Vector.svg" alt="">
          </span>
        </button>
      </div>
    </div>
  </footer>

  <script is:inline src="/site.js"></script>
</body>

</html>
