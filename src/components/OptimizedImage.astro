---
import { getOptimizedImageSources } from '../lib/media';
import type { ImageVariantSet } from '../lib/project-types';

interface Props extends astroHTML.JSX.ImgHTMLAttributes {
  src: string;
  alt: string;
  avifSrc?: string | null;
  webpSrc?: string | null;
  variants?: ImageVariantSet | null;
}

const { src, alt, avifSrc, webpSrc, variants, ...attributes } = Astro.props;
const optimizedSources = getOptimizedImageSources(src, variants);
const resolvedAvifSrc = avifSrc === undefined ? optimizedSources.avif : avifSrc;
const resolvedWebpSrc = webpSrc === undefined ? optimizedSources.webp : webpSrc;
const resolvedAvifSrcset = avifSrc === undefined ? optimizedSources.avifSrcset ?? resolvedAvifSrc : resolvedAvifSrc;
const resolvedWebpSrcset = webpSrc === undefined ? optimizedSources.webpSrcset ?? resolvedWebpSrc : resolvedWebpSrc;
const imageAttributes = {
  ...attributes,
  width: attributes.width ?? optimizedSources.width,
  height: attributes.height ?? optimizedSources.height,
};
---

<picture class="optimized-image-picture">
  {resolvedAvifSrcset && <source srcset={resolvedAvifSrcset} sizes={attributes.sizes} type="image/avif">}
  {resolvedWebpSrcset && <source srcset={resolvedWebpSrcset} sizes={attributes.sizes} type="image/webp">}
  <img src={src} alt={alt} decoding="async" {...imageAttributes}>
</picture>

<style>
  .optimized-image-picture { display: contents; }
</style>
