---
import { getLocalAvifSource } from '../lib/media';
import { categoryLabels, type Project } from '../lib/project-types';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const fallbackImage = { id: `${project.id}-cover`, url: project.coverUrl, alt: project.title, role: 'card' as const, sortOrder: 0 };
const mainImage = project.coverUrl ? fallbackImage : (project.cardImages[0] ?? fallbackImage);
const additionalImages = project.cardImages.filter((image) => image.url !== mainImage.url);
const sideImages = [additionalImages[0] ?? mainImage, additionalImages[1] ?? additionalImages[0] ?? mainImage];
const figmaMobileCovers: Record<string, string> = {
  'kriopigi-villas': '/img/figma-mobile/kriopigi-villas.png',
  'olympus-sea-view': '/img/figma-mobile/olympus-sea-view.png',
  'artemis-residences': '/img/figma-mobile/artemis-residences.png',
  'monastiriou-4-residences': '/img/figma-mobile/monastiriou-4-residences.png',
  'giannitson-thessaloniki': '/img/figma-mobile/giannitson-thessaloniki.png',
};
const mobileCoverUrl = figmaMobileCovers[project.slug] ?? mainImage.url;
const mobileCoverAvifUrl = getLocalAvifSource(mobileCoverUrl);
const mainImageAvifUrl = getLocalAvifSource(mainImage.url);
---

<article class="project-card" data-project-slug={project.slug} data-category={project.categories.join(' ')}>
  <div class="project-info">
    <div>
      <h3 class="project-name">{project.title}</h3>
      <p class="project-location"><span class="location-dot"></span>{project.address}</p>
      <p class="project-description">{project.shortDescription}</p>
    </div>
    <div class="project-bottom">
      <div class="project-price">{project.price}</div>
      <a href={`/projects/${project.slug}`} class="learn-more">Learn more <span></span></a>
    </div>
  </div>
  <div class="project-gallery">
    <div class="gallery-main">
      <picture>
        {mobileCoverAvifUrl && <source media="(max-width: 600px)" srcset={mobileCoverAvifUrl} type="image/avif">}
        <source media="(max-width: 600px)" srcset={mobileCoverUrl}>
        {mainImageAvifUrl && <source srcset={mainImageAvifUrl} type="image/avif">}
        <img src={mainImage.url} alt={mainImage.alt} loading="lazy" style={`object-position: ${project.coverFocalX}% ${project.coverFocalY}%;`}>
      </picture>
      <div class="project-tags">
        {project.categories.map((category) => <span class={`tag tag--${category}`}>{categoryLabels[category]}</span>)}
      </div>
    </div>
    <div class="gallery-sides">
      {sideImages.map((image) => (
        <picture class="project-card-side-picture">
          {getLocalAvifSource(image.url) && <source srcset={getLocalAvifSource(image.url)!} type="image/avif">}
          <img src={image.url} alt={image.alt} loading="lazy" style={`object-position: ${image.focalX ?? 50}% ${image.focalY ?? 50}%;`}>
        </picture>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card-side-picture {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
  }
</style>
