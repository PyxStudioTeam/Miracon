---
import type { Project } from '../lib/project-types';
import { getImageVariantSet, getLocalAvifSource, getOptimizedImageSources } from '../lib/media';
import { absoluteSiteUrl } from '../lib/seo';
import ContactSection from './ContactSection.astro';
import OptimizedImage from './OptimizedImage.astro';
import SeoHead from './SeoHead.astro';
import SiteFooter from './SiteFooter.astro';
import SiteHeader from './SiteHeader.astro';

interface Props {
  project: Project;
  preview?: boolean;
}

const { project, preview = false } = Astro.props;
const iconUrls = {
  bed: '/img/olympus-detail/icons/spec-bed.svg',
  bath: '/img/olympus-detail/icons/spec-bath.svg',
  area: '/img/olympus-detail/icons/spec-area.svg',
  levels: '/img/olympus-detail/icons/spec-lvl.svg',
};
const benefitIconClass = (iconUrl: string) => {
  const match = iconUrl.match(/amenity-([a-z-]+)\.svg$/i);
  return match ? `project-amenity-icon--${match[1]}` : 'project-amenity-icon--custom';
};
const gallerySource = project.gallery.length > 0
  ? project.gallery
  : [{ id: `${project.id}-gallery-cover`, url: project.coverUrl, alt: project.title, role: 'gallery' as const, sortOrder: 0 }, ...project.cardImages.filter((image) => image.url !== project.coverUrl)];
const gallery = [...gallerySource];
while (gallery.length > 0 && gallery.length < 4) gallery.push(gallery[gallery.length % gallerySource.length]);
const galleryClasses = ['project-gallery-image--far-left', 'project-gallery-image--left', 'project-gallery-image--main', 'project-gallery-image--right-small'];
const gallerySizes = [
  '(max-width: 1180px) 1px, 1091px',
  '(max-width: 1180px) 1px, 658px',
  '(max-width: 760px) 100vw, (max-width: 1180px) calc(100vw - 48px), 1402px',
  '(max-width: 1180px) 1px, 577px',
];
const galleryMedia = gallery.map((image) => {
  const sources = getOptimizedImageSources(image.url, getImageVariantSet(project.imageVariants, image.url));
  const src = sources.webp ?? sources.avif ?? getLocalAvifSource(image.url) ?? image.url;
  return {
    image,
    src,
    srcset: sources.webpSrcset ?? sources.avifSrcset,
    fallbackSrc: src !== image.url ? image.url : undefined,
  };
});
const mapSrc = `https://www.google.com/maps?q=${encodeURIComponent(project.mapQuery || project.address)}&output=embed`;
const mapHref = project.mapUrl || `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(project.mapQuery || project.address)}`;
const primaryCategory = project.categories[0] ?? 'coastal';
const publicPath = `/projects/${encodeURIComponent(project.slug)}`;
const publicUrl = absoluteSiteUrl(publicPath, Astro.url);
const heroImageUrl = project.heroUrl || project.coverUrl;
const heroImageVariants = getImageVariantSet(project.imageVariants, heroImageUrl);
const heroImageSources = getOptimizedImageSources(heroImageUrl, heroImageVariants);
const resolveVideoPlaylist = (videos: Project['heroVideos']) => videos
  .filter((video) => Boolean(video.desktopUrl.trim()))
  .map((video) => {
    const posterUrl = video.posterUrl ?? '';
    const posterSources = getOptimizedImageSources(posterUrl, getImageVariantSet(project.imageVariants, posterUrl));
    return {
      desktopUrl: video.desktopUrl,
      mobileUrl: video.mobileUrl,
      posterUrl: posterSources.webp || posterSources.avif || posterUrl || null,
    };
  });
const heroVideoPlaylist = resolveVideoPlaylist(project.heroVideos);
const walkthroughVideoPlaylist = resolveVideoPlaylist(project.walkthroughVideos);
const optimizedHeroPosterUrl = heroVideoPlaylist[0]?.posterUrl || project.heroPosterUrl || project.coverUrl;
const showWalkthroughVideo = project.walkthroughVideoEnabled && walkthroughVideoPlaylist.length > 0;
const walkthroughVideoTitle = project.walkthroughVideoTitle.trim() || 'Virtual walkthrough';
const showHeroVideo = project.heroType === 'video' && heroVideoPlaylist.length > 0;
const heroPreloadUrl = showHeroVideo
  ? optimizedHeroPosterUrl
  : heroImageSources.avif || heroImageSources.webp || heroImageUrl;
const heroPreloadType = heroPreloadUrl.endsWith('.avif')
  ? 'image/avif'
  : heroPreloadUrl.endsWith('.webp')
      ? 'image/webp'
      : undefined;
const heroPreloadSrcset = project.heroType === 'image'
  ? heroImageSources.avifSrcset || heroImageSources.webpSrcset
  : null;
const projectStructuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${publicUrl}#webpage`,
      url: publicUrl,
      name: project.seoTitle,
      description: project.seoDescription,
      image: absoluteSiteUrl(project.coverUrl, Astro.url),
      dateModified: project.updatedAt,
      inLanguage: 'en',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: absoluteSiteUrl('/', Astro.url) },
        { '@type': 'ListItem', position: 2, name: 'Projects', item: absoluteSiteUrl('/#projects', Astro.url) },
        { '@type': 'ListItem', position: 3, name: project.title, item: publicUrl },
      ],
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <base href="/">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <SeoHead
    title={preview ? `[Preview] ${project.seoTitle}` : project.seoTitle}
    description={project.seoDescription}
    path={publicPath}
    image={project.coverUrl}
    imageAlt={project.title}
    type="article"
    noindex={preview}
    jsonLd={preview ? undefined : projectStructuredData}
  />
  {heroPreloadUrl && <link rel="preload" as="image" href={heroPreloadUrl} type={heroPreloadType} imagesrcset={heroPreloadSrcset ?? undefined} imagesizes={heroPreloadSrcset ? '100vw' : undefined} fetchpriority="high">}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@qpokychuk/gilroy@1.0.2/index.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
  <link rel="stylesheet" href="/project.css">
  <link rel="stylesheet" href="/inner-mobile.css">
</head>
<body class:list={['project-page', `project-page--${project.heroVariant}`, { 'project-page--idle-hero': project.heroIdleUi && project.heroVariant === 'immersive' }]}>
  {preview && <div class="project-preview-banner">Draft preview <span>Only visible to the administrator</span></div>}
  <SiteHeader projectCategory={primaryCategory} />
  <main>
    <section
      class:list={['project-hero', `project-hero--${project.heroVariant}`]}
      aria-labelledby="project-title"
      data-project-hero
      data-idle-ui={String(project.heroIdleUi && project.heroVariant === 'immersive')}
      style={`--hero-focus-x: ${project.heroFocalX}%; --hero-focus-y: ${project.heroFocalY}%;`}
    >
      {showHeroVideo ? (
        <div class="project-hero-image project-hero-video project-video-deck" data-project-video-deck="hero" data-video-playlist={JSON.stringify(heroVideoPlaylist)}>
          <video class="project-video-slot is-active" poster={optimizedHeroPosterUrl || undefined} autoplay muted loop={heroVideoPlaylist.length === 1} playsinline preload="auto">
            {heroVideoPlaylist[0].mobileUrl && <source media="(max-width: 760px)" src={heroVideoPlaylist[0].mobileUrl} type="video/mp4">}
            <source src={heroVideoPlaylist[0].desktopUrl} type="video/mp4">
          </video>
          <video class="project-video-slot" muted playsinline preload="none"></video>
        </div>
      ) : (
        <OptimizedImage src={heroImageUrl} alt={project.title} variants={heroImageVariants} sizes="100vw" class="project-hero-image" fetchpriority="high" loading="eager" decoding="async" />
      )}
      {showHeroVideo && <button class="project-video-reduced-play" type="button" data-video-control-for="hero" aria-label="Play hero video">Play video</button>}
      {showHeroVideo && project.heroSoundEnabled && (
        <button class="project-hero-sound-button" type="button" aria-label="Enable video sound" aria-pressed="false">
          <img class="project-hero-sound-icon" src="/img/kriopigi-detail/sound.svg" alt="" aria-hidden="true">
          <span class="project-hero-sound-text">Sound</span>
        </button>
      )}
      <div class="container project-hero-content">
        <div class="project-hero-stack">
          <h1 id="project-title">{project.title}</h1>
          <a href={mapHref} class="project-location-link" target="_blank" rel="noreferrer">
            <img src="/img/olympus-detail/icons/hero-location.svg" alt="" class="project-location-icon" aria-hidden="true">
            <span class="project-location-text">{project.address}</span>
          </a>
          {project.brochureUrl && (
            <a href={project.brochureUrl} class="project-brochure-link" target="_blank" rel="noreferrer">
              <span class="project-brochure-icon" aria-hidden="true">
                <img src="/img/olympus-detail/icons/hero-brochure-1.svg" alt="" class="project-brochure-icon-part project-brochure-icon-part--tray">
                <img src="/img/olympus-detail/icons/hero-brochure-2.svg" alt="" class="project-brochure-icon-part project-brochure-icon-part--chevron">
                <img src="/img/olympus-detail/icons/hero-brochure-3.svg" alt="" class="project-brochure-icon-part project-brochure-icon-part--stem">
              </span>
              <span>Brochure</span>
            </a>
          )}
        </div>
      </div>
    </section>

    <section class="project-intro" aria-labelledby="project-intro-title">
      <div class="container project-intro-grid">
        <div class="project-intro-media">
          <h2 id="project-intro-title" class="project-section-title">{project.introTitle}</h2>
          <OptimizedImage src={project.introImageUrl || project.coverUrl} alt={`${project.title} interior`} variants={getImageVariantSet(project.imageVariants, project.introImageUrl || project.coverUrl)} sizes="(max-width: 900px) calc(100vw - 48px), (max-width: 1450px) 51vw, 1002px" class="project-intro-image" loading="lazy" decoding="async" />
        </div>
        <div class="project-intro-copy">
          {project.characteristics.length > 0 && (
            <div class="project-specs" aria-label="Project specifications">
              {project.characteristics.map((item) => (
                <div class="project-spec">
                  <img src={iconUrls[item.icon]} alt="" class="project-spec-icon" aria-hidden="true">
                  <span>{item.label}: <strong>{item.value}</strong></span>
                </div>
              ))}
            </div>
          )}
          <p class="project-description-full">{project.fullDescription}</p>
        </div>
      </div>
    </section>

    {project.benefits.length > 0 && (
      <section class="project-amenities" aria-labelledby="project-amenities-title">
        <div class="container project-amenities-grid">
          <div class="project-amenities-heading">
            <h2 id="project-amenities-title" class="project-section-title">Amenities</h2>
            <p>Every residence designed for comfort, views, and lasting quality</p>
          </div>
          <div class="project-amenities-list">
            {project.benefits.map((benefit) => (
              <article class="project-amenity-card">
                <img src={benefit.icon} alt="" class:list={['project-amenity-icon', benefitIconClass(benefit.icon)]} aria-hidden="true">
                <h3>{benefit.title}</h3>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {gallery.length > 0 && (
      <section id="project-gallery" class="project-gallery-strip" aria-label={`${project.title} gallery`}>
        <div class="project-gallery-track">
          {galleryMedia.slice(0, 4).map(({ image, src, srcset, fallbackSrc }, index) => (
            <img
              src={src}
              srcset={srcset ?? undefined}
              sizes={gallerySizes[index]}
              alt={image.alt}
              loading="lazy"
              decoding="async"
              class={`project-gallery-image ${galleryClasses[index]}`}
              data-fallback-src={fallbackSrc}
              data-focal-x={image.focalX ?? 50}
              data-focal-y={image.focalY ?? 50}
              style={`object-position: ${image.focalX ?? 50}% ${image.focalY ?? 50}%;`}
            >
          ))}
          {galleryMedia.slice(4).map(({ image, src, srcset, fallbackSrc }) => (
            <span
              class="project-gallery-source"
              data-src={src}
              data-srcset={srcset ?? undefined}
              data-fallback-src={fallbackSrc}
              data-alt={image.alt}
              data-focal-x={image.focalX ?? 50}
              data-focal-y={image.focalY ?? 50}
              hidden
            ></span>
          ))}
        </div>
        {gallerySource.length > 1 && (
          <div class="project-gallery-controls" role="group" aria-label="Gallery navigation">
            <button class="project-gallery-arrow project-gallery-arrow--previous" type="button" aria-label="Previous image"><span aria-hidden="true">←</span></button>
            <button class="project-gallery-arrow project-gallery-arrow--next" type="button" aria-label="Next image"><span aria-hidden="true">→</span></button>
          </div>
        )}
        {project.brochureUrl && (
          <a href={project.brochureUrl} class="project-floating-brochure" target="_blank" rel="noreferrer">
            <img src="/img/olympus-detail/icons/brochure-circle.svg" alt="" class="project-floating-icon" aria-hidden="true"><span>Brochure</span>
          </a>
        )}
      </section>
    )}

    {showWalkthroughVideo && (
      <section class="project-walkthrough" aria-labelledby="project-walkthrough-title">
        <div class="container project-walkthrough-inner">
          <h2 id="project-walkthrough-title" class="project-section-title">{walkthroughVideoTitle}</h2>
          <div class="project-walkthrough-video project-video-deck" data-project-video-deck="walkthrough" data-has-mobile={String(walkthroughVideoPlaylist.some((video) => Boolean(video.mobileUrl)))} data-video-playlist={JSON.stringify(walkthroughVideoPlaylist)}>
            <video class="project-video-slot is-active" poster={walkthroughVideoPlaylist[0].posterUrl || undefined} autoplay muted loop={walkthroughVideoPlaylist.length === 1} playsinline preload="metadata">
              {walkthroughVideoPlaylist[0].mobileUrl && <source media="(max-width: 760px)" src={walkthroughVideoPlaylist[0].mobileUrl} type="video/mp4">}
              <source src={walkthroughVideoPlaylist[0].desktopUrl} type="video/mp4">
            </video>
            <video class="project-video-slot" muted playsinline preload="none"></video>
            <button class="project-video-reduced-play" type="button" aria-label="Play walkthrough video">Play video</button>
          </div>
        </div>
      </section>
    )}

    {project.floorPlanGroups.length > 0 && (
      <section class="project-floor-plans" aria-labelledby="project-floor-title">
        <div class="container">
          <h2 id="project-floor-title" class="project-section-title">Floor plans</h2>
          <p class="project-section-subtitle">Modern living, perfectly designed</p>
          <div class="project-plan-tabs" aria-label="Floor plan types">
            {project.floorPlanGroups.map((group, index) => (
              <button class:list={['project-plan-tab', { active: index === 0 }]} type="button" data-plan-filter={group.id}><span data-label={group.title}>{group.title}</span></button>
            ))}
          </div>
          <div class="project-plan-list">
            {project.floorPlanGroups.flatMap((group, groupIndex) => group.plans.map((plan) => (
              <article class="project-plan-card" data-plan={group.id} hidden={groupIndex !== 0}>
                <h3>{plan.title}</h3><OptimizedImage src={plan.imageUrl} alt={plan.alt} variants={getImageVariantSet(project.imageVariants, plan.imageUrl)} sizes="(max-width: 760px) calc(100vw - 40px), (max-width: 1180px) calc(100vw - 48px), min(1720px, calc(100vw - 200px))" loading="lazy" decoding="async" />
              </article>
            )))}
          </div>
        </div>
      </section>
    )}

    <section class="project-location-section" aria-label={`${project.title} location`} data-map-src={mapSrc}>
      <div class="project-location-map-shell"><iframe class="project-location-map" title={`Map showing ${project.address}`} loading="lazy" referrerpolicy="no-referrer-when-downgrade" aria-hidden="true"></iframe></div>
      {project.nearbyPlaces.length > 0 && (
        <div class="project-location-marquee" aria-label="Nearby places">
          <div class="project-location-track">
            <div class="project-location-set">{project.nearbyPlaces.map((place) => <span>{place}</span>)}</div>
            <div class="project-location-set" aria-hidden="true">{project.nearbyPlaces.map((place) => <span>{place}</span>)}</div>
          </div>
        </div>
      )}
    </section>

    <ContactSection />
  </main>
  <SiteFooter />
  <script is:inline src="/site.js"></script>
</body>
</html>

<style>
  .project-description-full { white-space: pre-line; }
  .project-preview-banner { position: fixed; z-index: 100; top: 12px; left: 50%; padding: 10px 18px; border-radius: 999px; background: #b68a3d; color: white; font: 600 13px/1.2 Arial, sans-serif; transform: translateX(-50%); box-shadow: 0 8px 30px rgba(0, 48, 117, .25); }
  .project-preview-banner span { margin-left: 10px; opacity: .75; font-weight: 400; }
</style>
